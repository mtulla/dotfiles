{
  "env": {
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "USE_BUILTIN_RIPGREP": "0"
  },
  "permissions": {
    "allow": [
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(file:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(shellcheck:*)",
      "Bash(grep:*)",
      "Bash(tr:*)",
      "Bash(lsof:*)",
      "Bash(head:*)",
      "Bash(xxd:*)",
      "Bash(git grep:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git stash list:*)",
      "Bash(git check-ignore:*)",
      "Bash(git show-ref:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr checks:*)"
    ]
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": false,
    "lua-lsp@claude-plugins-official": true,
    "go-code-reviewer@datadog-claude-plugins": true,
    "feature-dev@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "atlassian@claude-plugins-official": true,
    "osx-notifications@datadog-claude-plugins": true,
    "web-ui-skills@mat-brown-contrib": true,
    "common-mistakes@mat-brown-contrib": true,
    "permissions@mat-brown-contrib": true,
    "pr-description@mat-brown-contrib": true
  },
  "autoUpdatesChannel": "stable"
}
